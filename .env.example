# Sui Network
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
SUI_GRAPHQL_URL=https://graphql.mainnet.sui.io/graphql

# EVE Frontier World
WORLD_PACKAGE_ID=0x_DISCOVER_FROM_WORLD_CONTRACTS
GHOST_PACKAGE_ID=0x_SET_AFTER_PUBLISHING_GHOST_TERMINAL
TENANT=stillness

# Polling
POLLING_INTERVAL_MS=1000

# LLM Provider (set one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Backend Server
PORT=3001
CORS_ORIGIN=*

# Frontend (used by dApp at build time)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_DEMO_MODE=false
